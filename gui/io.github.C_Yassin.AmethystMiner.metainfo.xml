<component type="desktop-application">
    <id>io.github.C_Yassin.AmethystMiner</id>
    <metadata_license>FSFAP</metadata_license>
    <project_license>MIT</project_license>
    <name>Amethyst Miner</name>
    <summary>Mine Monero with high performance</summary>
    
    <description>
        <p>Mine Monero with elegance. Amethyst Miner is a high-performance RandomX CPU miner wrapped in a beautiful, native GUI, allowing you to maximize your hash rate without touching the command line.</p>
        <ul>
            <li>Sleek, native dashboard to track your hashrate and estimated profits</li>
            <li>Live performance data and historical hashrate charts</li>
            <li>Advanced configuration including CPU thread allocation and priority</li>
            <li>Built-in support for easily enabling the MSR hardware mod</li>
            <li>Automated background mining capabilities</li>
            <li>Full dark mode support built with native UI toolkits</li>
            <li>100% open-source transparency</li>
        </ul>
    </description>
    
    <launchable type="desktop-id">io.github.C_Yassin.AmethystMiner.desktop</launchable>
    <content_rating type="oars-1.1"/>
    
    <branding>
        <color type="primary" scheme_preference="light">#4dd0e1</color>
        <color type="primary" scheme_preference="dark">#33a1f5</color>
    </branding>
    
